# ============================================================
# .env.example — Variables d'environnement du projet OCP Tickets
# ============================================================
# 1. Copier ce fichier : cp .env.example .env
# 2. Remplir toutes les valeurs
# 3. NE JAMAIS committer .env dans Git (.gitignore doit l'exclure)
# ============================================================

# --- Django ---
SECRET_KEY=remplacez-par-une-cle-aleatoire-longue-et-unique
DEBUG=True
# En production, listez les domaines autorisés séparés par des virgules
# Exemple : ALLOWED_HOSTS=tickets.ocp.ma,api.tickets.ocp.ma
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de données PostgreSQL ---
DB_NAME=ticketing_db
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe_db
DB_HOST=localhost
DB_PORT=5432

# --- JWT ---
# Durée de vie du token d'accès (en minutes)
JWT_ACCESS_MINUTES=60
# Durée de vie du token de rafraîchissement (en jours)
JWT_REFRESH_DAYS=7

# --- LLM (Semaine 5-6) ---
# Clé API OpenAI ou compatible (Mistral, Groq, etc.)
OPENAI_API_KEY=sk-...
# Modèle à utiliser : gpt-4o, gpt-3.5-turbo, mistral-small, etc.
LLM_MODEL=gpt-4o-mini
